{
  "name": "easyaiflow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "predev": "node scripts/prepare-dev.mjs",
    "dev": "concurrently -k \"npm:dev:web:client\" \"npm:dev:desktop\"",
    "dev:web": "concurrently -k \"npm:dev:web:client\" \"npm:dev:server\"",
    "dev:web:client": "vite",
    "dev:desktop": "wait-on http-get://127.0.0.1:4173 && npm run build:electron && electron .",
    "dev:server": "tsx server/server.ts",
    "build": "npm run check && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:web": "npm run check && vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "tsc -b",
    "preview": "vite preview",
    "start:web": "node dist-server/server.js",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.aiagent.easyaiflow",
    "productName": "EasyAIFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
